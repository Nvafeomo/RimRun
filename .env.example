EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Android Google Maps (Maps SDK for Android) — required for map tiles in production builds
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=your-google-maps-android-api-key

# Native Google Sign-In (OAuth 2.0 client IDs from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Reversed iOS client ID for the Expo config plugin (com.googleusercontent.apps.xxxx)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# Optional (GitHub Pages defaults in constants/legal.ts)
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://nvafeomo.github.io/RimRun/privacy/privacy-policy.html
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://nvafeomo.github.io/RimRun/termsofservice/

# --- EAS Build (set via `eas secret:create`, not in git) ---
# Same EXPO_PUBLIC_* vars as above are injected into preview/production builds.
# See docs/TESTING.md for TestFlight / Play internal testing setup.
