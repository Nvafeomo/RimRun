{
  "expo": {
    "plugins": [
      ["@react-native-community/datetimepicker", {
        "android": {
          "datePicker": {
            "textColorSecondary": { "light": "#94A3B8", "dark": "#94A3B8" }
          }
        }
      }]
    ],
    "scheme": "rimrun",
    "name": "RimRun",
    "slug": "RimRun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/rimrun-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RimRun uses your location to show nearby basketball courts on the map.",
        "NSPhotoLibraryUsageDescription": "RimRun needs access to your photos to set your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "RimRun needs access to your photos to set your profile picture.",
        "NSCameraUsageDescription": "RimRun needs camera access to take your profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.nvafeomo.RimRun"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
