{
  "expo": {
    "plugins": [
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "textColorSecondary": "#94A3B8"
            }
          }
        }
      ],
      "expo-web-browser"
    ],
    "scheme": "rimrun",
    "name": "RimRun",
    "slug": "RimRun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/rimrun-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nvafeomo.RimRun",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RimRun uses your location to show nearby basketball courts on the map.",
        "NSPhotoLibraryUsageDescription": "RimRun needs access to your photos to set your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "RimRun needs access to your photos to set your profile picture.",
        "NSCameraUsageDescription": "RimRun needs camera access to take your profile picture."
      }
    },
    "android": {
      "splash": {
        "image": "./assets/rimrun-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "package": "com.nvafeomo.RimRun"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
